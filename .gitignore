# ===== Node / pnpm / yarn / npm =====
node_modules/
.pnpm-store/
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.yarn/sdks

# Lockfile policy: we commit `pnpm-lock.yaml` (frontend uses pnpm).
# Anti-lockfile noise from incidental package managers:
package-lock.json
yarn.lock
bun.lockb

# ===== Go =====
vendor/
bin/
*.exe
*.test
*.out
*.cover
coverage.out

# ===== Build outputs =====
dist/
build/
out/

# ===== Vite / React =====
*.local
.vite/
# TanStack Router auto-generated file is INTENTIONALLY committed — the
# Vite plugin regenerates it on `dev` / `build` and TS needs it to
# typecheck on a fresh clone. Do NOT add `routeTree.gen.ts` here.

