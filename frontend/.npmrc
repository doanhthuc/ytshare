# pnpm settings
# Install missing peer deps automatically — React 19 + the TanStack
# ecosystem produce noisy peer warnings otherwise.
auto-install-peers=true

# Hoist common deps so editors / Vite plugins resolve them at the root
# of node_modules. We're not in a workspace so the strict default
# (only direct deps visible) hides things like `react` from sub-packages
# that omit it from peerDependencies.
shamefully-hoist=true
