# Server
APP_ENV=development
HTTP_PORT=8080
LOG_LEVEL=info

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=ytshare
DB_PASSWORD=ytshare
DB_NAME=ytshare
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=change-me-please-access
JWT_REFRESH_SECRET=change-me-please-refresh
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_HOURS=168

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Schema migrations (golang-migrate)
# MIGRATIONS_DIR is read by both `cmd/server` (boot) and `cmd/migrate` (CLI).
MIGRATIONS_DIR=./migrations

